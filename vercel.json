{
  "crons": [
    {
      "path": "/api/process-publish-jobs",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/auto-post/run-due-rules",
      "schedule": "5 1 * * *"
    },
    {
      "path": "/api/auto-post/check-kling-task",
      "schedule": "10 1 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * data: blob: 'unsafe-inline' 'unsafe-eval'; connect-src * https://*.facebook.com https://*.fbcdn.net https://www.googleapis.com https://oauth2.googleapis.com;"
        }
      ]
    }
  ]
}
